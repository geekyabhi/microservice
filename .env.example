# Copy this file to .env and fill in your values.
# The project starts with defaults even without a .env file.

# ── JWT secret ────────────────────────────────────────────
APP_SECRET=ecommerce_super_secret_change_in_prod

# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── PostgreSQL (mail service) ──────────────────────────────
POSTGRES_USER=notification
POSTGRES_PASSWORD=notification
POSTGRES_DB=notifications

# ── Razorpay (payments service) ───────────────────────────
RAZORPAY_API_KEY=
RAZORPAY_API_SECRET=
